{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "* * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/onboarding",
      "destination": "/settings.html"
    },
    {
      "source": "/today",
      "destination": "/today.html"
    },
    {
      "source": "/history",
      "destination": "/history.html"
    },
    {
      "source": "/settings",
      "destination": "/settings.html"
    },
    {
      "source": "/api/:match*",
      "destination": "/api/[...slug]"
    }
  ]
}
